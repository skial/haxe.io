<!doctype html>
<html lang="en" class="/roundups">
	<head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="color-scheme" content="light dark">
        <link rel="alternate" type="application/atom+xml" href="/atom.xml" />
        <link rel="alternate" type="application/rss+xml" href="/rss.xml" />
        <link title="Original Pre 2026 Haxe.io Feed" rel="alternate" type="application/rss+xml" href="http://blog.skialbainn.com/rss" />
        <link webc:keep rel="stylesheet" href="/css/roundups.css">
        <title @text="title ?? payload.title"></title>
	</head>
	<body>
    </body>
</html>
<script webc:type="js">
    export default function(context) {
        let data = {};
        data = context.$data;
        return context.renderTemplate(`<hio-roundup>${data.content}</hio-roundup>`, "webc", data)
        .then(function(str) {
            return context.renderTemplate(str, "liquid", data);
        });
    }
</script>