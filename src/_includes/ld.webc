<!doctype html>
<html lang="en" class="/ld">
	<head>
        <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="color-scheme" content="light dark">
        <link webc:keep rel="stylesheet" href="/css/gamejam.css">
        <title @text="title ?? payload.title"></title>
	</head>
	<body>
    </body>
</html>
<script webc:type="js">
    export default function(context) {
        let data = {};
        data = context.$data;
        return context.renderTemplate(`<hio-ludumdare>${data.content}</hio-ludumdare>`, "webc", data)
        .then(function(str) {
            return context.renderTemplate(str, "liquid", data);
        });
    }
</script>